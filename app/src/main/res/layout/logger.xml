<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="@dimen/widget_padding"
    android:orientation="vertical"
    android:background="@drawable/round"
    android:clickable="true"
    android:focusable="true">

    <!-- Title -->
    <TextView
        android:id="@+id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/title"
        android:textSize="14sp"
        android:textColor="@color/weather_on_surface"
        android:textStyle="bold"
        android:paddingBottom="6dp" />

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15000000"
        android:layout_marginBottom="8dp" />

    <!-- Current Temperature -->
    <TextView
        android:id="@+id/temperature"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/na"
        android:drawableStart="@drawable/ic_temperature"
        android:drawablePadding="8dp"
        android:gravity="center_vertical"
        android:textSize="22sp"
        android:textColor="@color/weather_on_surface"
        android:textStyle="bold"
        android:paddingBottom="4dp" />

    <!-- 12h Min / Max -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="42dp"
        android:paddingBottom="12dp">

        <ImageView
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:src="@drawable/ic_min_max"
            android:contentDescription="@string/temp_min_max_label" />

        <TextView
            android:id="@+id/temp_min_max"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/na"
            android:textSize="13sp"
            android:textColor="@color/weather_on_surface_medium"
            android:paddingStart="4dp" />
    </LinearLayout>

    <!-- Divider -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#10000000"
        android:layout_marginBottom="4dp" />

    <!-- Last update + refresh -->
    <TextView
        android:id="@+id/created_on"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:gravity="center_vertical"
        android:drawableEnd="@drawable/ic_baseline_refresh_24"
        android:drawablePadding="4dp"
        android:text="@string/na"
        android:textSize="11sp"
        android:textColor="@color/weather_on_surface_medium" />

</LinearLayout>