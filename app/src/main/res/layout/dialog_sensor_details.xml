<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/detail_name"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/weather_on_surface"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/detail_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="@color/weather_primary"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/detail_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/weather_on_surface_medium"
        android:paddingBottom="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#15000000"
        android:layout_marginBottom="16dp" />

    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="2"
        android:alignmentMode="alignMargins">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kind:"
            android:textStyle="bold"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"/>
        <TextView
            android:id="@+id/info_kind"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Space:"
            android:textStyle="bold"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"/>
        <TextView
            android:id="@+id/info_space"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Space UUID:"
            android:textStyle="bold"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"/>
        <TextView
            android:id="@+id/info_space_uuid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:paddingBottom="4dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sensor UUID:"
            android:textStyle="bold"
            android:paddingEnd="8dp"
            android:paddingBottom="4dp"/>
        <TextView
            android:id="@+id/info_sensor_uuid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:paddingBottom="4dp"/>
    </GridLayout>

</LinearLayout>